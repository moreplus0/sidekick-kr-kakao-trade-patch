diff --git a/src/Sidekick.Common/Converters/StringOrObjectListJsonConverter.cs b/src/Sidekick.Common/Converters/StringOrObjectListJsonConverter.cs
new file mode 100644
index 0000000..8417774
--- /dev/null
+++ b/src/Sidekick.Common/Converters/StringOrObjectListJsonConverter.cs
@@ -0,0 +1,90 @@
+using System.Text.Json;
+using System.Text.Json.Serialization;
+
+namespace Sidekick.Common.Converters;
+
+public class StringOrObjectListJsonConverter : JsonConverter<List<string>>
+{
+    public override List<string> Read(ref Utf8JsonReader reader, Type typeToConvert, JsonSerializerOptions options)
+    {
+        var values = new List<string>();
+
+        if (reader.TokenType == JsonTokenType.Null)
+        {
+            return values;
+        }
+
+        if (reader.TokenType != JsonTokenType.StartArray)
+        {
+            AddValue(ref reader, values);
+            return values;
+        }
+
+        while (reader.Read() && reader.TokenType != JsonTokenType.EndArray)
+        {
+            AddValue(ref reader, values);
+        }
+
+        return values;
+    }
+
+    public override void Write(Utf8JsonWriter writer, List<string> value, JsonSerializerOptions options)
+    {
+        writer.WriteStartArray();
+        foreach (var item in value)
+        {
+            writer.WriteStringValue(item);
+        }
+
+        writer.WriteEndArray();
+    }
+
+    private static void AddValue(ref Utf8JsonReader reader, List<string> values)
+    {
+        switch (reader.TokenType)
+        {
+            case JsonTokenType.String:
+                var stringValue = reader.GetString();
+                if (!string.IsNullOrWhiteSpace(stringValue))
+                {
+                    values.Add(stringValue);
+                }
+
+                break;
+
+            case JsonTokenType.StartObject:
+                using (var document = JsonDocument.ParseValue(ref reader))
+                {
+                    if (TryGetString(document.RootElement, "description", out var description) ||
+                        TryGetString(document.RootElement, "text", out description))
+                    {
+                        values.Add(description);
+                    }
+                }
+
+                break;
+
+            default:
+                reader.Skip();
+                break;
+        }
+    }
+
+    private static bool TryGetString(JsonElement element, string propertyName, out string value)
+    {
+        value = string.Empty;
+        if (!element.TryGetProperty(propertyName, out var property) || property.ValueKind != JsonValueKind.String)
+        {
+            return false;
+        }
+
+        var stringValue = property.GetString();
+        if (string.IsNullOrWhiteSpace(stringValue))
+        {
+            return false;
+        }
+
+        value = stringValue;
+        return true;
+    }
+}
