@@ -0,0 +1,55 @@
+using System.Text.Json;
+using Sidekick.Apis.Poe.Trade.Trade.Models;
+using Xunit;
+
+namespace Sidekick.Apis.Poe.Tests.Trade;
+
+public class ApiItemModListParsing
+{
+    [Fact]
+    public void DeserializesModsReturnedAsStringsOrObjects()
+    {
+        const string json = """
+        {
+          "implicitMods": [
+            "[Accuracy|정확도] +141"
+          ],
+          "explicitMods": [
+            {
+              "description": "[Accuracy|정확도] +143",
+              "hash": "stat.explicit.stat_803737631",
+              "mods": [
+                {
+                  "magnitudes": [
+                    {
+                      "min": "100",
+                      "max": "150"
+                    }
+                  ]
+                }
+              ]
+            },
+            {
+              "text": "[Evasion|회피] +129"
+            },
+            "발견하는 [ItemRarity|아이템 희귀도] 16% 증가"
+          ]
+        }
+        """;
+
+        var item = JsonSerializer.Deserialize<ApiItem>(json, new JsonSerializerOptions
+        {
+            PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
+        });
+
+        Assert.NotNull(item);
+        Assert.Equal(["[Accuracy|정확도] +141"], item.ImplicitMods);
+        Assert.Equal(
+            [
+                "[Accuracy|정확도] +143",
+                "[Evasion|회피] +129",
+                "발견하는 [ItemRarity|아이템 희귀도] 16% 증가",
+            ],
+            item.ExplicitMods);
+    }
+}
